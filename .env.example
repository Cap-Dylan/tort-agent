# ──────────────────────────────────────────────────────────────────
# Tort Agent — Environment Config
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real tokens.
# ──────────────────────────────────────────────────────────────────


# ── Canvas LMS ────────────────────────────────────────────────────
# Get your token: Canvas → Account → Settings → New Access Token
CANVAS_API_TOKEN=your_canvas_api_token_here
CANVAS_BASE_URL=https://your-school.instructure.com


# ── Obsidian Vault ────────────────────────────────────────────────
# Absolute path to your vault root.
# For tower deployment with the vault on another machine, mount the
# vault as a network share or sync it via Syncthing / iCloud and
# point at the local mount path here.
OBSIDIAN_VAULT=/path/to/your/obsidian/vault


# ── iCloud Notes Staging (macOS only) ─────────────────────────────
# Where export_apple_notes saves PDFs and convert_notes reads them.
# Subfolder per course: {this path}/ECON204/, {this path}/CO300/, etc.
ICLOUD_NOTES_DIR=/Users/your-username/Library/Mobile Documents/com~apple~CloudDocs/HandwrittenNotes


# ── Weather ───────────────────────────────────────────────────────
# Used by morning_brief — any city wttr.in recognizes.
WEATHER_LOCATION=Denver


# ── Ollama ────────────────────────────────────────────────────────
# OLLAMA_URL is the host running Ollama. For tower deployment over
# Tailscale, this looks like http://tower.your-tail-net.ts.net:11434
# For local dev, http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Recommended models (pick one):
#   qwen3.6:35b-a3b   ← intended target (RTX 4090 / 24GB+ VRAM)
#   qwen3:14b         ← good fallback if you have ~16GB VRAM
#   qwen2.5:7b        ← runs on most consumer hardware
OLLAMA_MODEL=qwen3.6:35b-a3b


# ── History ───────────────────────────────────────────────────────
# How many turns to keep in conversation history before truncation.
MAX_HISTORY=20
