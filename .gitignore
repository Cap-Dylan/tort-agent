# ── Secrets ───────────────────────────────────────────────────────
# Never commit. Real tokens belong in .env (which lives only on your
# machine). Copy .env.example → .env to set up locally.
.env
.env.local
*.env
!.env.example


# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual envs
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg


# ── Tooling ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/


# ── IDE / editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~


# ── OS junk ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# ── Local agent state ─────────────────────────────────────────────
# Conversation history written by agent-chat (if you use it)
chat_history.json
*.log
